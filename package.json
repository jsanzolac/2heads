{
  "name": "2heads",
  "version": "0.1.0",
  "description": "A tmux-backed terminal REPL for making Claude and Codex challenge each other before you decide.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "2heads": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "cli",
    "tmux",
    "claude",
    "codex",
    "ai",
    "repl",
    "decision-making"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsanzolac/2heads.git"
  },
  "bugs": {
    "url": "https://github.com/jsanzolac/2heads/issues"
  },
  "homepage": "https://github.com/jsanzolac/2heads#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/cli.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
